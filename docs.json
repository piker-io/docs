{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Piker",
  "logo": {
    "dark": "/logo/dark.svg",
    "light": "/logo/light.svg"
  },
  "favicon": "/favicon.svg",
  "backgroundImage": "/images/hero-bg.png",
  "colors": {
    "primary": "#A0A0C8",
    "light": "#C8A840",
    "dark": "#A0A0C8"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Home",
        "pages": ["home"]
      },
      {
        "tab": "User Guide",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "guide/introduction",
              "guide/quickstart",
              "guide/two-modes"
            ]
          },
          {
            "group": "Rookie Mode",
            "pages": [
              "guide/rookie/overview",
              "guide/rookie/daily-capital",
              "guide/rookie/trading",
              "guide/rookie/leaderboard",
              "guide/rookie/streaks",
              "guide/rookie/badges"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "reference/pairs",
              "reference/order-types",
              "reference/faq"
            ]
          }
        ]
      },
      {
        "tab": "Pro Mode",
        "groups": [
          {
            "group": "Pro Mode",
            "pages": [
              "pro/overview",
              "pro/piker-score",
              "pro/tiers",
              "pro/trading",
              "pro/leaderboard",
              "pro/milestones"
            ]
          }
        ]
      },
      {
        "tab": "Fund Me",
        "groups": [
          {
            "group": "Fund Me",
            "pages": [
              "fundme/overview",
              "fundme/for-traders",
              "fundme/for-backers",
              "fundme/profit-split"
            ]
          }
        ]
      },
      {
        "tab": "Solana & On-Chain",
        "groups": [
          {
            "group": "Solana & On-Chain",
            "pages": [
              "solana/overview",
              "solana/rank-sbt",
              "solana/badge-nfts",
              "solana/vaults"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Twitter",
          "icon": "twitter",
          "href": "https://twitter.com/piker_io"
        },
        {
          "anchor": "Discord",
          "icon": "discord",
          "href": "https://discord.gg/piker"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Home",
        "href": "/home"
      },
      {
        "label": "App",
        "href": "https://piker.io"
      }
