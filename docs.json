    "primary": {
      "type": "button",
      "label": "Start Playing",
      "href": "https://piker.io/signup"
    }
  },
  "footer": {
    "socials": {
      "x": "https://twitter.com/piker_io",
      "discord": "https://discord.gg/piker"
    }
  }
